rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /quiz_attempts/{id} {
      allow read:
      if request.auth != null;

      allow write:
      if request.auth != null;
    }

    match /profiles/{id} {
      allow read:
      if request.auth != null;

      allow write:
      if request.auth.uid == id;
    }

  }
}
